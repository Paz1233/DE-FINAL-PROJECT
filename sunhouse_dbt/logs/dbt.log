[0m16:43:08.672916 [debug] [Thread-1 (]: On model.sunhouse_dbt.gold_flights: /* {"app": "dbt", "dbt_version": "1.12.0b3", "profile_name": "sunhouse_dbt", "target_name": "dev", "node_id": "model.sunhouse_dbt.gold_flights"} */

  
    

    create table "iceberg"."sunhouse"."gold_flights"
      
      WITH (location = 'abfs://warehouse@dataengineering2025sa.dfs.core.windows.net/SunHouse/Gold/flights/')
    as (
      

WITH latest_updates AS (

    SELECT *
    FROM (
        SELECT
            *,
            ROW_NUMBER() OVER (
                PARTITION BY flight_id
                ORDER BY update_time DESC
            ) AS rn
        FROM "iceberg"."sunhouse"."silver_updates"
    )
    WHERE rn = 1

)

SELECT
    fs.flight_id,
    fs.flight_number,
    fs.departure_date,
    fs.departure_airport,
    fs.destination_airport,
    fs.airline_name,

    f.total_seats,
    f.fuel_consumption,
    f.fuel_price_per_liter,
    f.crew_members,

    u.status,
    u.updated_at,
    u.status,
    u.new_departure_date

FROM "iceberg"."sunhouse"."silver_flight_schedule" fs

LEFT JOIN "iceberg"."sunhouse"."silver_flights" f
    ON f.flight_id = fs.flight_id

LEFT JOIN latest_updates u
    ON u.flight_id = fs.flight_id
    )
