[0m14:37:47.154321 [debug] [Thread-1 (]: On model.sunhouse_dbt.silver_flight_schedule: /* {"app": "dbt", "dbt_version": "1.12.0b3", "profile_name": "sunhouse_dbt", "target_name": "dev", "node_id": "model.sunhouse_dbt.silver_flight_schedule"} */

  
    

    create table "iceberg"."sunhouse"."silver_flight_schedule"
      
      WITH (location = 'abfs://warehouse@dataengineering2025sa.dfs.core.windows.net/SunHouse/Silver/flight-schedule/')
    as (
      

WITH raw_extracted AS (
    SELECT
        flightnumber,
        TRIM(departuredate) AS raw_date,
        TRIM(departuretime) AS raw_time,
        departure,
        destination,
        airline
    FROM "hive"."sunhouse"."raw_flight_schedule"
    WHERE flightnumber IS NOT NULL 
      AND departuredate IS NOT NULL
),

prepped_strings AS (
    SELECT
        flightnumber,
        departure,
        destination,
        airline,
        raw_time,
        -- 1. Combine date and time ONLY if raw_date doesn't already contain a time component
        CASE 
            WHEN raw_date LIKE '%:%' THEN raw_date
            WHEN raw_time IS NOT NULL AND raw_time != '' THEN CONCAT(raw_date, ' ', raw_time)
            ELSE CONCAT(raw_date, ' 00:00:00') -- Absolute fallback if both lack time
        END AS combined_datetime_str
    FROM raw_extracted
),

standardized_datetime AS (
    SELECT
        flightnumber,
        departure,
        destination,
        airline,
        -- 2. Now parse the unified string safely based on slash vs hyphen formats
        CASE 
            -- Handles 'DD/MM/YYYY HH:mm' or 'DD/MM/YYYY hh:mm AM/PM'
            WHEN combined_datetime_str LIKE '%/%' AND (combined_datetime_str LIKE '%AM%' OR combined_datetime_str LIKE '%PM%') THEN 
                CAST(DATE_PARSE(combined_datetime_str, '%d/%m/%Y %h:%i %p') AS TIMESTAMP(3))
            WHEN combined_datetime_str LIKE '%/%' THEN 
                CAST(DATE_PARSE(combined_datetime_str, '%d/%m/%Y %H:%i') AS TIMESTAMP(3))
            
            -- Handles standard 'YYYY-MM-DD HH:mm' or 'YYYY-MM-DD hh:mm AM/PM'
            WHEN combined_datetime_str LIKE '%-%' AND (combined_datetime_str LIKE '%AM%' OR combined_datetime_str LIKE '%PM%') THEN 
                CAST(DATE_PARSE(combined_datetime_str, '%Y-%m-%d %h:%i %p') AS TIMESTAMP(3))
            ELSE 
                CAST(DATE_PARSE(combined_datetime_str, '%Y-%m-%d %H:%i') AS TIMESTAMP(3))
        END AS full_departure_timestamp
    FROM prepped_strings
),

clean_bronze AS (
    SELECT
        UPPER(REGEXP_REPLACE(TRIM(flightnumber), '[^a-zA-Z0-9]')) AS clean_flight_number,
        
        -- 3. Extract a clean string date (YYYY-MM-DD) for macro ID consistency across the lakehouse
        CAST(CAST(full_departure_timestamp AS DATE) AS VARCHAR) AS clean_departure_date,
        
        full_departure_timestamp,
        COALESCE(UPPER(TRIM(departure)), 'UNKNOWN') AS departure_airport,
        COALESCE(UPPER(TRIM(destination)), 'UNKNOWN') AS destination_airport,
        COALESCE(UPPER(TRIM(airline)), 'UNKNOWN') AS airline_name
    FROM standardized_datetime
),

surrogate_key_generation AS (
    SELECT
        -- 4. Run macro with the pristine YYYY-MM-DD string format
        
    LOWER(
        TO_HEX(
            MD5(
                CAST(
                    CONCAT(
                        UPPER(REGEXP_REPLACE(TRIM(clean_flight_number), '[^a-zA-Z0-9]')),
                        '_',
                        TRIM(clean_departure_date)
                    ) AS VARBINARY
                )
            )
        )
    )
 AS flight_id,
        clean_flight_number AS flight_number,
        departure_airport,
        destination_airport,
        airline_name,
        full_departure_timestamp AS departure_date
    FROM clean_bronze
)

SELECT
    flight_id,
    flight_number,
    departure_airport,
    destination_airport,
    airline_name,
    departure_date
FROM surrogate_key_generation
    )
