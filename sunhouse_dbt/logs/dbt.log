    create table "iceberg"."sunhouse"."silver_flights"
      
      WITH (location = 'abfs://warehouse@dataengineering2025sa.dfs.core.windows.net/SunHouse/Silver/flights/')
    as (
      

WITH clean_bronze_flights AS (
    SELECT
        -- 1. Clean the flight number business key
        UPPER(REGEXP_REPLACE(TRIM(number), '[^a-zA-Z0-9]')) AS clean_flight_number,
        
        -- 2. Implement the fallback rule for the departure date
        COALESCE(CAST(TRIM(departure) AS DATE), CAST(TRIM(date) AS DATE)) AS clean_departure_date,
        
        -- Clean up operational metrics safely
        TRY_CAST(TRIM(fuel_consumption) AS INT) AS fuel_consumption,
        TRY_CAST(TRIM(fuel_price_per_liter) AS DECIMAL(10, 4)) AS fuel_price_per_liter,
        TRY_CAST(TRIM(crew_members) AS INT) AS crew_members
    FROM "hive"."sunhouse"."raw_flights"
    -- Filter out completely broken records where identity is impossible
    WHERE number IS NOT NULL 
      AND (departure IS NOT NULL OR date IS NOT NULL)
),

flights_with_ids AS (
    SELECT
        -- 3. Use your macro to generate the exact matching flight_id
        
    LOWER(
        TO_HEX(
            MD5(
                CAST(
                    CONCAT(
                        UPPER(REGEXP_REPLACE(TRIM(clean_flight_number), '[^a-zA-Z0-9]')),
                        '_',
                        TRIM(clean_departure_date)
                    ) AS VARBINARY
                )
            )
        )
    )
 AS flight_id,
        clean_flight_number AS flight_number,
        CAST(CONCAT(clean_departure_date, ' 00:00:00') AS TIMESTAMP(3)) AS departure_timestamp,
        fuel_consumption,
        fuel_price_per_liter,
        crew_members
    FROM clean_bronze_flights
),

-- 4. Calculate actual total seats dynamically from your silver bookings table
booked_seats_agg AS (
    SELECT
        flight_id,
        SUM(passenger_count) AS actual_total_seats
    -- Referencing your upstream silver model ensures dbt DAG dependencies stay intact!
    FROM "iceberg"."sunhouse"."silver_flight_booking"
    GROUP BY flight_id
)

SELECT
    f.flight_id,
    f.flight_number,
    f.departure_timestamp,
    -- Coalesce to 0 in case a flight exists but has 0 bookings yet
    COALESCE(b.actual_total_seats, 0) AS total_seats,
    f.fuel_consumption,
    f.fuel_price_per_liter,
    f.crew_members
FROM flights_with_ids f
LEFT JOIN booked_seats_agg b 
    ON f.flight_id = b.flight_id
    )
