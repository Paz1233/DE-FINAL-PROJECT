                        '_',
                        TRIM(clean_departure_date)
                    ) AS VARBINARY
                )
            )
        )
    )
 AS flight_id,
        clean_flight_number AS flight_number,
        departure_airport,
        destination_airport,
        airline_name,
        full_departure_timestamp AS departure_date
    FROM clean_bronze
)

SELECT
    flight_id,
    flight_number,
    departure_airport,
    destination_airport,
    airline_name,
    departure_date
FROM surrogate_key_generation
    )
