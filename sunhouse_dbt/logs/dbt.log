    as (
      

WITH clean_bronze AS (
    SELECT
        -- Standardize business keys for the macro
        UPPER(REGEXP_REPLACE(TRIM(flightnumber), '[^a-zA-Z0-9]')) AS clean_flight_number,
        TRIM(departuredate) AS clean_departure_date,
        
        -- Clean up time string
        TRIM(departuretime) AS clean_departure_time,
        
        -- Coalesce missing airport/airline strings to prevent null propagation downstream
        COALESCE(UPPER(TRIM(departure)), 'UNKNOWN') AS departure_airport,
        COALESCE(UPPER(TRIM(destination)), 'UNKNOWN') AS destination_airport,
        COALESCE(TRIM(airline), 'UNKNOWN') AS airline_name
    FROM "hive"."sunhouse"."raw_flight_schedule"
    -- Drop records where we cannot establish a flight identity or date
    WHERE flightnumber IS NOT NULL 
      AND departuredate IS NOT NULL
),

surrogate_key_generation AS (
    SELECT
        -- Apply your reusable macro to create a consistent flight_id
        
    LOWER(
        TO_HEX(
            MD5(
                CAST(
                    CONCAT(
                        UPPER(REGEXP_REPLACE(TRIM(clean_flight_number), '[^a-zA-Z0-9]')),
                        '_',
                        TRIM(clean_departure_date)
                    ) AS VARBINARY
                )
            )
        )
    )
 AS flight_id,
        clean_flight_number AS flight_number,
        departure_airport,
        destination_airport,
        airline_name,
        
        -- Combine date and time cleanly into a full precision timestamp
        CASE 
            WHEN clean_departure_time IS NULL OR clean_departure_time = '' THEN
                CAST(CONCAT(clean_departure_date, ' 00:00:00') AS TIMESTAMP(3))
            WHEN clean_departure_time LIKE '%AM%' OR clean_departure_time LIKE '%PM%' THEN
                CAST(DATE_PARSE(CONCAT(clean_departure_date, ' ', clean_departure_time), '%Y-%m-%d %h:%i %p') AS TIMESTAMP(3))
            ELSE
                CAST(DATE_PARSE(CONCAT(clean_departure_date, ' ', clean_departure_time), '%Y-%m-%d %H:%i') AS TIMESTAMP(3))
        END AS departure_date
    FROM clean_bronze
)

SELECT
    flight_id,
    flight_number,
    departure_airport,
    destination_airport,
    airline_name,
    departure_date
FROM surrogate_key_generation
    )
