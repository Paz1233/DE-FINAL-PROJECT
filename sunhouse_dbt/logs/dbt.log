                CAST(DATE_PARSE(CONCAT(clean_check_in_date, ' ', clean_check_in_time), '%Y-%m-%d %h:%i %p') AS TIMESTAMP(3))
            ELSE
                CAST(DATE_PARSE(CONCAT(clean_check_in_date, ' ', clean_check_in_time), '%Y-%m-%d %H:%i') AS TIMESTAMP(3))
        END AS check_in_date
    FROM raw_check_in
)

