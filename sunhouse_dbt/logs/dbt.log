    create table "iceberg"."sunhouse"."silver_flight_schedule"
      
      WITH (location = 'abfs://warehouse@dataengineering2025sa.dfs.core.windows.net/SunHouse/Silver/flight-schedule/')
    as (
      

WITH raw_extracted AS (
    SELECT
        flightnumber,
        TRIM(departuredate) AS raw_date,
        TRIM(departuretime) AS raw_time,
        departure,
        destination,
        airline
    FROM "hive"."sunhouse"."raw_flight_schedule"
    WHERE flightnumber IS NOT NULL 
      AND departuredate IS NOT NULL
),

standardized_datetime AS (
    SELECT
        -- 1. Parse the messy departuredate column dynamically based on format
        CASE 
            -- Handles 'DD/MM/YYYY HH:mm' or 'MM/DD/YYYY HH:mm' (e.g., 03/05/2026 5:30)
            WHEN raw_date LIKE '%/%' AND raw_date LIKE '%:%' THEN 
                CAST(DATE_PARSE(raw_date, '%d/%m/%Y %H:%i') AS TIMESTAMP(3))
            -- Handles 'DD/MM/YYYY' without time
            WHEN raw_date LIKE '%/%' THEN 
                CAST(DATE_PARSE(raw_date, '%d/%m/%Y') AS TIMESTAMP(3))
            -- Fallback to standard standard YYYY-MM-DD
            ELSE 
                CAST(DATE_PARSE(SPLIT(raw_date, ' ')[1], '%Y-%m-%d') AS TIMESTAMP(3))
        END AS full_departure_timestamp,
        
        flightnumber,
        raw_time,
        departure,
        destination,
        airline
    FROM raw_extracted
),

clean_bronze AS (
    SELECT
        UPPER(REGEXP_REPLACE(TRIM(flightnumber), '[^a-zA-Z0-9]')) AS clean_flight_number,
        
        -- 2. Extract a clean string date (YYYY-MM-DD) for macro ID consistency
        CAST(CAST(full_departure_timestamp AS DATE) AS VARCHAR) AS clean_departure_date,
        
        full_departure_timestamp,
        COALESCE(UPPER(TRIM(departure)), 'UNKNOWN') AS departure_airport,
        COALESCE(UPPER(TRIM(destination)), 'UNKNOWN') AS destination_airport,
        COALESCE(UPPER(TRIM(airline)), 'UNKNOWN') AS airline_name
    FROM standardized_datetime
),

surrogate_key_generation AS (
    SELECT
        -- 3. Run macro with the pristine YYYY-MM-DD string format
        
    LOWER(
        TO_HEX(
            MD5(
                CAST(
                    CONCAT(
                        UPPER(REGEXP_REPLACE(TRIM(clean_flight_number), '[^a-zA-Z0-9]')),
                        '_',
                        TRIM(clean_departure_date)
                    ) AS VARBINARY
                )
            )
        )
    )
 AS flight_id,
        clean_flight_number AS flight_number,
        departure_airport,
        destination_airport,
        airline_name,
        full_departure_timestamp AS departure_date
    FROM clean_bronze
)

SELECT
    flight_id,
    flight_number,
    departure_airport,
    destination_airport,
    airline_name,
    departure_timestamp
FROM surrogate_key_generation
    )
