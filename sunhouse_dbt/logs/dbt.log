[0m17:28:41.112539 [debug] [Thread-1 (]: On model.sunhouse_dbt.gold_booking: /* {"app": "dbt", "dbt_version": "1.12.0b3", "profile_name": "sunhouse_dbt", "target_name": "dev", "node_id": "model.sunhouse_dbt.gold_booking"} */

  
    

    create table "iceberg"."sunhouse"."gold_booking"
      
      WITH (location = 'abfs://warehouse@dataengineering2025sa.dfs.core.windows.net/SunHouse/Gold/bookings/')
    as (
      

WITH booking AS (

    SELECT *
    FROM "iceberg"."sunhouse"."silver_flight_booking"

),

checkin AS (

    SELECT
        booking_id,
        check_in_date
    FROM "iceberg"."sunhouse"."silver_check_in"

),

rates AS (

    SELECT
        date,
        currency_type,
        coin_value
    FROM "iceberg"."sunhouse"."silver_coin_change"

),

payments AS (

    SELECT
        booking_id,
        COUNT(*) AS num_of_payments
    FROM "iceberg"."sunhouse"."silver_payments"
    GROUP BY booking_id

)

SELECT

    b.booking_id,
    b.user_id,
    b.flight_id,
    b.passenger_count,

    b.booking_date,

    c.check_in_date,

    ROUND(
        b.flight_price * COALESCE(r.coin_value,1),
        2
    ) AS flight_price_ils,

    COALESCE(p.num_of_payments,0) AS num_of_payments,

    date_diff(
        'minute',
        c.check_in_date,
        f.departure_datetime
    ) AS checkin_to_departure_minutes,

    date_diff(
        'hour',
        b.booking_date,
        c.check_in_date
    ) AS from_booking_to_check_in_hours

FROM booking b

LEFT JOIN checkin c
    ON b.booking_id = c.booking_id

LEFT JOIN rates r
    ON r.currency_type = b.currency_type
   AND r.date = CAST(b.booking_date AS DATE)

LEFT JOIN payments p
    ON p.booking_id = b.booking_id

LEFT JOIN "iceberg"."sunhouse"."silver_flights" f
    ON b.flight_id = f.flight_id


    )
