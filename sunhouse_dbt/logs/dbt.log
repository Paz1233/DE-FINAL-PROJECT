[0m13:20:08.176280 [debug] [Thread-1 (]: On model.sunhouse_dbt.silver_check_in: /* {"app": "dbt", "dbt_version": "1.12.0b3", "profile_name": "sunhouse_dbt", "target_name": "dev", "node_id": "model.sunhouse_dbt.silver_check_in"} */

  
    

    create table "iceberg"."sunhouse"."silver_check_in"
      
      WITH (location = 'abfs://warehouse@dataengineering2025sa.dfs.core.windows.net/SunHouse/Silver/check-in/')
    as (
      

WITH raw_check_in AS (
    SELECT
        -- Call your brand new macro here!
        
    CAST(
        xxhash64(
            CAST(
                CONCAT(
                    UPPER(REGEXP_REPLACE(TRIM(flight_number), '[^a-zA-Z0-9]')),
                    '_',
                    TRIM(departure_date)
                ) AS VARBINARY
            )
        ) AS BIGINT
    )
 AS flight_id,
        id as booking_id,
        TRIM("check in date") AS clean_check_in_date,
        TRIM("check in time") AS clean_check_in_time
    FROM "hive"."sunhouse"."raw_check_in"
    WHERE flight_number IS NOT NULL 
      AND departure_date IS NOT NULL
      AND check_in_date IS NOT NULL
),

normalized_timestamps AS (
    SELECT
        flight_id,
        booking_id,
        CASE 
            WHEN clean_check_in_time LIKE '%AM%' OR clean_check_in_time LIKE '%PM%' THEN
                CAST(DATE_PARSE(CONCAT(clean_check_in_date, ' ', clean_check_in_time), '%Y-%m-%d %h:%i %p') AS TIMESTAMP(3))
            ELSE
                CAST(DATE_PARSE(CONCAT(clean_check_in_date, ' ', clean_check_in_time), '%Y-%m-%d %H:%i') AS TIMESTAMP(3))
        END AS check_in_date
    FROM raw_check_in
)

SELECT
    flight_id,
    booking_id
    check_in_date
FROM normalized_timestamps
    )
